@model ContactModel
<div class="row" style="background-color: #ffffff; color: #000000; padding: 20px;">

    <div class="col-sm-3">
        <div class="companyinfo">
            <p><img src="~/media/logo/@Model.LogoImg" width="200px" height="120px" /></p>
            <p style="color: #000000;">@Html.Raw(@Model.Description)</p>
        </div>
    </div>
    <div class="col-sm-5 col-md-5">
        @Html.Raw(@Model.Map)
    </div>
    <div class="col-sm-4">
        <div class="address">
            <h5 style="color: #000000;"><b>Name : @Model.Name</b></h5>
            <h5 style="color: #000000;">Email : @Model.Email</h5>
            <h5 style="color: #000000;">@Model.Phone</h5>
        </div>
    </div>

</div>