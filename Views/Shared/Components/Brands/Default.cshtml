@model IEnumerable<Xedap.Models.BrandModel>

<li class="nav-item dropdown mega-dropdown">
    <a class="nav-link dropdown-toggle fw-semibold" href="#" id="brandDropdown"
       role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fa fa-star me-2"></i> Thương Hiệu
    </a>

    <!-- Mega Dropdown -->
    <div class="dropdown-menu mega-menu p-4" aria-labelledby="brandDropdown">
        <div class="row g-3">
            @foreach (var brand in Model)
            {
                <div class="col-6 col-sm-4 col-md-3">
                    <a class="dropdown-item text-wrap d-flex align-items-center"
                       asp-controller="Brand"
                       asp-action="Index"
                       asp-route-slug="@brand.Slug">
                        <i class="fa fa-tags text-muted me-2"></i> @brand.Name
                    </a>
                </div>
            }
        </div>
    </div>
</li>

<style>
    /* ====== Mega Dropdown (Thương hiệu) ====== */
    .mega-dropdown {
        position: relative;
    }

    /* Hover: hiển thị menu */
    .mega-dropdown:hover .dropdown-menu {
        display: block !important;
        opacity: 1;
        visibility: visible;
    }

    /* Mega menu chính */
    .mega-menu {
        position: absolute;
        top: 100%;
        left: 0;
        transform: none;
        min-width: 900px;
        background-color: #fff;
        border-radius: 10px;
        border: 1px solid #eee;
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.1);
        z-index: 1050;
        display: none;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    /* Item */
    .mega-menu .dropdown-item {
        padding: 6px 10px;
        border-radius: 6px;
        color: #333;
        font-size: 15px;
        transition: all 0.2s ease-in-out;
    }

    .mega-menu .dropdown-item:hover {
        background-color: #f8f9fa;
        color: #ee4d2d;
        transform: translateX(3px);
    }

    /* ✅ Hiển thị chuẩn khi ở chế độ mobile (Bootstrap collapse) */
    .navbar-collapse.show .mega-menu {
        position: static !important;
        width: 100% !important;
        transform: none !important;
        box-shadow: none !important;
        border: none !important;
        display: block !important;
        opacity: 1 !important;
        visibility: visible !important;
    }
</style>
