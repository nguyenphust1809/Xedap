<div class="left-sidebar">

    <!-- Danh mục -->
    <div class="panel-group category-products" id="accordian">
        <vc:categories></vc:categories>
    </div>

    <!-- Thương hiệu -->
    <div class="panel-group category-products" id="accordian">
        <vc:brands></vc:brands>
    </div>

    <!-- Lọc theo giá -->
    <div class="panel-group category-products mt-3">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h4 class="panel-title" style="font-weight:600; color:#333; padding:10px 0;">
                    <i class="fa fa-tag me-2" style="color:#fe980f;"></i> Lọc theo giá
                </h4>
            </div>
            <div class="panel-body" style="padding:10px 0;">
                <div style="display:flex; justify-content:space-between; font-size:14px; margin-bottom:6px;">
                    <span id="minPriceLabel">0 ₫</span>
                    <span id="maxPriceLabel">20,000,000 ₫</span>
                </div>
                <input type="range" id="priceRange" min="0" max="20000000" step="500000" value="20000000"
                       style="width:100%; accent-color:#fe980f;" />
                <div style="font-size:13px; color:#888; margin-top:6px;">
                    Giá tối đa: <strong id="selectedPrice" style="color:#e74c3c;">20,000,000 ₫</strong>
                </div>
                <button onclick="applyPriceFilter()" class="btn btn-sm btn-warning w-100 mt-2" style="background:#fe980f; border:none; color:#fff; font-weight:600;">
                    Áp dụng
                </button>
            </div>
        </div>
    </div>

    <!-- Sản phẩm nổi bật (static placeholder) -->
    <div class="panel-group category-products mt-3">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h4 class="panel-title" style="font-weight:600; color:#333; padding:10px 0;">
                    <i class="fa fa-fire me-2" style="color:#fe980f;"></i> Sản phẩm nổi bật
                </h4>
            </div>
            <div class="panel-body">
                @inject Xedap.Repository.DataContext _sidebarContext
                @foreach (var p in _sidebarContext.Products.OrderByDescending(x => x.Sold).Take(3).ToList())
                {
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
                        <img src="~/media/products/@p.Image" style="width:55px; height:55px; object-fit:contain; border-radius:8px; border:1px solid #eee;" />
                        <div>
                            <div style="font-size:13px; font-weight:600; line-height:1.3;">@p.Name</div>
                            <div style="font-size:13px; color:#e74c3c; font-weight:bold;">@p.Price.ToString("N0") ₫</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

</div>

<script>
    var priceRange = document.getElementById('priceRange');
    var selectedPrice = document.getElementById('selectedPrice');
    var maxPriceLabel = document.getElementById('maxPriceLabel');

    if (priceRange) {
        priceRange.addEventListener('input', function () {
            var val = parseInt(this.value).toLocaleString('vi-VN') + ' ₫';
            selectedPrice.innerText = val;
            maxPriceLabel.innerText = val;
        });
    }

    function applyPriceFilter() {
        var maxPrice = document.getElementById('priceRange').value;
        var url = new URL(window.location.href);
        url.searchParams.set('maxPrice', maxPrice);
        window.location.href = url.toString();
    }
</script>
