@model Xedap.Models.AppUserModel

@{
    ViewData["Title"] = "Cập nhật thông tin";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <style>
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            min-height: 100vh;
            font-family: "Segoe UI", sans-serif;
            background: #f0f2f5;
        }

        .update-wrapper {
            max-width: 500px;
            margin: 60px auto;
            background: #fff;
            border-radius: 20px;
            padding: 40px 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

            .update-wrapper h2 {
                text-align: center;
                margin-bottom: 25px;
                font-weight: 600;
                color: #333;
            }

        .form-control {
            height: 45px;
            border-radius: 12px;
            font-size: 0.95rem;
        }

        .btn-primary {
            width: 100%;
            border-radius: 12px;
            height: 48px;
            font-weight: 500;
            font-size: 1rem;
            background: linear-gradient(135deg, #007bff, #6c63ff);
            border: none;
            transition: all 0.3s;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(0,123,255,0.3);
            }

        .text-success {
            text-align: center;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .form-label {
            font-weight: 500;
        }

        .password-wrapper {
            position: relative;
        }

            .password-wrapper i {
                position: absolute;
                top: 50%;
                right: 15px;
                transform: translateY(-50%);
                cursor: pointer;
                color: #888;
            }

    </style>
</head>

<body>
    <div class="update-wrapper">
        <h2>Cập nhật thông tin tài khoản</h2>

        @if (TempData["success"] != null)
        {
            <div class="text-success">@TempData["success"]</div>
        }

        <form autocomplete="off" asp-action="UpdateInfoAccount" asp-controller="Account" method="post">
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input asp-for="UserName" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Số điện thoại</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="mb-3 password-wrapper">
                <label class="form-label">Mật khẩu mới</label>
                <input type="password" name="PasswordHash" required class="form-control" placeholder="Nhập mật khẩu mới" />
                <i class="fa fa-eye-slash toggle-password"></i>
                <span asp-validation-for="PasswordHash" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary mt-3">Cập nhật</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>

    <script>
        // Toggle password visibility
        const togglePassword = document.querySelector('.toggle-password');
        const passwordInput = document.querySelector('input[name="PasswordHash"]');
        togglePassword.addEventListener('click', () => {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            togglePassword.classList.toggle('fa-eye');
            togglePassword.classList.toggle('fa-eye-slash');
        });
    </script>

    @section Scripts {
        @await Html.PartialAsync("_ValidationScriptsPartial")
    }
</body>
</html>
