@model IEnumerable<Xedap.Models.OrderModel>

@{
    ViewData["Title"] = "Lịch sử đặt hàng";
}

<div class="container mt-6 pt-5" style="margin-top:120px !important;">
    <h3 class="mb-4 fw-bold text-center">
        Lịch sử đặt hàng của
        <span class="text-warning">@ViewBag.UserEmail</span>
    </h3>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model.OrderByDescending(o => o.CreatedDate))
            {
                <div class="col-12">
                    <div class="card shadow-sm" style="border-left: 4px solid #fe980f; border-radius: 12px;">
                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="fw-bold mb-0">Đơn hàng #@item.OrderCode</h5>
                                <span class="badge px-3 py-2" style="background-color:@GetStatusColor(item.Status); color:white; border-radius:8px;">
                                    @GetStatusText(item.Status)
                                </span>
                            </div>

                            <div class="mb-2">
                                <p class="mb-1"><strong>Ngày đặt:</strong> @item.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                                <p class="mb-1"><strong>Thanh toán:</strong> @(string.IsNullOrEmpty(item.PaymentMethod) ? "-" : (item.PaymentMethod == "COD" ? "COD" : $"Qua MOMO {item.PaymentMethod}"))</p>
                                <p class="mb-1"><strong>Giá vận chuyển:</strong> @item.ShippingCost.ToString("#,##0 VNĐ")</p>
                                <p class="mb-1"><strong>Giảm giá:</strong> @(item.CouponCode ?? "-")</p>
                                <p class="mb-1"><strong>Tên khách:</strong> @item.UserName</p>
                            </div>

                            <a asp-controller="Account" asp-action="OrderDetails" asp-route-orderCode="@item.OrderCode"
                               class="btn btn-sm text-white me-2" style="background-color:#fe980f;">
                                <i class="fa fa-info-circle me-1"></i> Xem chi tiết
                            </a>


                                @if (item.Status == 1) 
                                {
                                    <a asp-controller="Account" asp-action="CancelOrder" asp-route-ordercode="@item.OrderCode"
                                       class="btn btn-sm btn-warning">
                                        <i class="fa fa-times-circle me-1"></i> Hủy
                                    </a>
                                }
                            </div>

                        </div>
                    </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="fa fa-info-circle me-2"></i> Bạn chưa có đơn hàng nào.
        </div>
    }
</div>

@functions {
    private string GetStatusText(int status)
    {
        return status switch
        {
            1 => "Chờ xác nhận",
            2 => "Chờ lấy hàng",
            3 => "Đang giao hàng",
            4 => "Đã giao",
            5 => "Trả hàng / Hoàn tiền",
            6 => "Đã hủy",
            _ => "Không xác định"
        };
    }

    private string GetStatusColor(int status)
    {
        return status switch
        {
            1 => "#ff9800",   // cam
            2 => "#2196f3",   // xanh dương
            3 => "#673ab7",   // tím
            4 => "#4caf50",   // xanh lá
            5 => "#e91e63",   // hồng
            6 => "#9e9e9e",   // xám
            _ => "#000"
        };
    }
}
