@model IEnumerable<Xedap.Models.ProductModel>

@{
    ViewData["Title"] = "Sản phẩm đang giảm giá";
    Layout = null;
}

<style>
    body {
        background: #f8f9fa;
        font-family: "Poppins", sans-serif;
        margin: 0;
        padding: 0;
    }

    .sale-header {
        text-align: center;
        color: #e91e63;
        font-weight: 700;
        margin: 40px 0 30px;
        font-size: 2.2rem;
    }

    .container {
        max-width: 1200px;
        margin: auto;
        padding: 0 15px;
    }

    .row.g-4 {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    .col-md-3, .col-sm-6 {
        flex: 1 1 calc(25% - 20px);
        box-sizing: border-box;
    }

     (max-width: 992px) {
        .col-md-3

    {
        flex: 1 1 calc(33.333% - 20px);
    }

    }

     (max-width: 768px) {
        .col-md-3, .col-sm-6

    {
        flex: 1 1 calc(50% - 20px);
    }

    }

     (max-width: 576px) {
        .col-md-3, .col-sm-6

    {
        flex: 1 1 100%;
    }

    }

    .card {
        background: #fff;
        border-radius: 15px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        height: 100%;
    }

        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
        }

    .card-img-top {
        height: 250px;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .card:hover .card-img-top {
        transform: scale(1.05);
    }

    .card-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 15px;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 5px;
        min-height: 48px; /* giữ chiều cao đều nhau */
    }

    .price {
        color: #ff5722;
        font-weight: bold;
        font-size: 1.2rem;
        margin: 5px 0;
    }

    .text-muted {
        font-size: 0.85rem;
        margin-bottom: 10px;
        color: #6c757d;
    }

    .btn-sale {
        background: linear-gradient(90deg, #ff5722, #ff9800);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 8px 0;
        font-weight: 600;
        transition: opacity 0.3s, transform 0.3s;
    }

        .btn-sale:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }

    .empty-message {
        text-align: center;
        margin-top: 100px;
        font-size: 1.2rem;
        color: gray;
    }

    .badge-sale {
        position: absolute;
        top: 15px;
        left: 15px;
        background: #ff5252;
        color: #fff;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 5px 8px;
        border-radius: 10px;
        z-index: 10;
    }

    .card-img-wrapper {
        position: relative;
    }
</style>

<h2 class="sale-header">🔥 SẢN PHẨM DƯỚI 200.000₫ 🔥</h2>

<div class="container my-5">
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="empty-message">Hiện chưa có sản phẩm nào được giảm giá.</div>
        }
        else
        {
            @foreach (var product in Model)
            {
                <div class="col-md-3 col-sm-6">
                    <div class="card">
                        <div class="card-img-wrapper">
                            <img src="~/media/products/@product.Image" class="card-img-top" alt="@product.Name" />
                            @* Nếu muốn hiển thị badge giảm giá *@
                            <span class="badge-sale">Sale</span>
                        </div>
                        <div class="card-body text-center">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="price">@string.Format("{0:N0}₫", product.Price)</p>
                            <p class="text-muted small">@product.Category?.Name | @product.Brand?.Name</p>
                            <a href="@Url.Action("Details", "Product", new { id = product.Id })"
                               class="btn btn-sale w-100">Xem chi tiết</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
