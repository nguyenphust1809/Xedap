@model IEnumerable<ProductModel>
@{
    ViewData["Title"] = "Danh mục sản phẩm";
}

@section Styles {
    <style>
        .product-card {
            background: #fff;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 4px 14px rgba(0,0,0,0.08);
            transition: 0.3s ease;
            display: flex;
            flex-direction: column;
            height: 430px; /* cố định chiều cao */
        }

            .product-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 8px 22px rgba(0,0,0,0.12);
            }

        .product-img {
            height: 230px;
            object-fit: contain;
            padding: 16px;
        }

        .product-info {
            text-align: center;
            padding: 15px;
            min-height: 150px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }

            .product-info h3 {
                font-size: 17px;
                font-weight: 600;
                margin-top: 10px;
                /* Giới hạn 2 dòng */
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
                text-overflow: ellipsis;
                min-height: 45px;
            }

        .price {
            color: #e74c3c;
            font-weight: bold;
            font-size: 20px;
        }

        .product-meta {
            font-size: 14px;
            color: #666;
        }

        .product-actions {
            padding: 12px;
            border-top: 1px solid #eee;
            background: #fafafa;
        }

        .btn-add {
            background: #27ae60;
            color: #fff;
            font-weight: 600;
            border-radius: 8px;
        }

            .btn-add:hover {
                background: #1f8b4e;
            }

        .btn-out {
            background: #bfc6ce;
            color: #444;
            border-radius: 8px;
        }

        .filter-box {
            background: #fff;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }
    </style>
}

<div class="container" style="margin-top:140px;">
    <div class="row">

        <!-- Sidebar -->
        <div class="col-lg-3">
            @Html.Partial("_SideBarPartial")
        </div>

        <!-- Product Area -->
        <div class="col-lg-9">

            <!-- SORT BY -->
            <div class="filter-box d-flex justify-content-between align-items-center flex-wrap">

                <div>
                    <label class="fw-semibold me-2">Sắp xếp:</label>
                    <select id="sort_by" class="form-select d-inline-block w-auto">
                        <option value="">Mặc định</option>
                        <option value="?sort_by=price_increase">Giá tăng dần</option>
                        <option value="?sort_by=price_decrease">Giá giảm dần</option>
                        <option value="?sort_by=price_newest">Mới nhất</option>
                        <option value="?sort_by=price_oldest">Cũ nhất</option>
                    </select>
                </div>
            </div>

            <!-- Products -->
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-12 col-sm-6 col-md-4">
                        <div class="product-card">

                            <img src="~/media/products/@item.Image"
                                 class="product-img"
                                 alt="@item.Name" />

                            <div class="product-info">
                                <div class="price">@item.Price.ToString("N0") ₫</div>

                                <h3>@item.Name</h3>

                                <div class="product-meta">
                                    Danh mục: @item.Category.Name <br />
                                    Thương hiệu: @item.Brand.Name
                                </div>
                            </div>

                            <div class="product-actions">
                                @if (item.Quantity > 0)
                                {
                                    <a href="#" class="btn btn-add w-100">
                                        <i class="fa fa-shopping-cart"></i> Thêm vào giỏ
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-out w-100" disabled>Hết hàng</button>
                                }
                            </div>

                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Apply sorting
        $('#sort_by').on('change', function () {
            const url = $(this).val();
            if (url) window.location = url;
        });
    </script>
}
