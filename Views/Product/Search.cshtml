@model IEnumerable<ProductModel>

@{
    ViewData["Title"] = "Kết quả tìm kiếm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <!-- 🔹 Không còn sidebar, nội dung chiếm toàn bộ -->
        <div class="col-sm-12">
            <h2 class="title text-center mb-4">
                Kết quả cho: <strong>@ViewBag.Keyword</strong>
            </h2>

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning text-center">
                    <i class="fa fa-info-circle"></i>
                    Không tìm thấy sản phẩm nào phù hợp với từ khóa
                    "<strong>@ViewBag.Keyword</strong>".
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var item in Model)
                    {
                        <div class="col-md-4 col-sm-6 mb-4">
                            <div class="product-image-wrapper shadow-sm rounded h-100">
                                <div class="single-products h-100">
                                    <div class="productinfo text-center p-3">
                                        <img src="@Url.Content($"~/media/products/{item.Image}")"
                                             alt="@item.Name"
                                             class="img-fluid rounded"
                                             style="height:200px; object-fit:cover;" />

                                        <h5 class="text-danger mt-2">
                                            @item.Price.ToString("N0") ₫
                                        </h5>

                                        <p class="fw-semibold text-truncate" title="@item.Name">
                                            @item.Name
                                        </p>

                                        <p>Danh mục: <strong>@item.Category?.Name</strong></p>
                                        <p>Thương hiệu: <strong>@item.Brand?.Name</strong></p>

                                        @if (item.Quantity > 0)
                                        {
                                            <a asp-action="Add"
                                               asp-controller="Cart"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-primary mt-2">
                                                <i class="fa fa-shopping-cart"></i> Thêm vào giỏ
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-secondary mt-2" disabled>
                                                <i class="fa fa-exclamation-circle"></i> Hết hàng
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
