@{
    ViewData["Title"] = "Thống kê";
}


<div class="row g-4">
    <!-- Card Sản phẩm -->
    <div class="col-md-3">
        <div class="card shadow border-0 h-100 bg-primary text-white rounded-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase opacity-75" style="color: #fe980f;">Sản phẩm</h6>
                    <h2 class="fw-bold mb-0">@(ViewBag.CountProduct ?? 0)</h2>
                </div>
                <i class="fas fa-box fa-3x opacity-75"></i>
            </div>
        </div>
    </div>

    <!-- Card Đơn hàng đã xử lý -->
    <div class="col-md-3">
        <div class="card shadow border-0 h-100 bg-success text-white rounded-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase opacity-75" style="color: #fe980f;">Đơn hàng</h6>
                    <h2 class="fw-bold mb-0">@(ViewBag.CountOrder ?? 0)</h2>
                </div>
                <i class="fas fa-shopping-cart fa-3x opacity-75"></i>
            </div>
        </div>
    </div>

    <!-- Card Danh mục -->
    <div class="col-md-3">
        <div class="card shadow border-0 h-100 bg-warning text-dark rounded-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase opacity-75" style="color: #fe980f;">Danh mục</h6>
                    <h2 class="fw-bold mb-0">@(ViewBag.CountCategory ?? 0)</h2>
                </div>
                <i class="fas fa-tags fa-3x opacity-75"></i>
            </div>
        </div>
    </div>

    <!-- Card Người dùng -->
    <div class="col-md-3">
        <div class="card shadow border-0 h-100 bg-danger text-white rounded-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase opacity-75" style="color: #fe980f;">Người dùng</h6>
                    <h2 class="fw-bold mb-0">@(ViewBag.CountUser ?? 0)</h2>
                </div>
                <i class="fas fa-users fa-3x opacity-75"></i>
            </div>
        </div>
    </div>
</div>

<!-- Filter + Legend -->
<div class="row mt-4">
    <div class="col-md-4">
        <h5>Lọc dữ liệu theo</h5>
        <select class="form-select filter-select">
            <option value="">-- Chọn thời gian --</option>
            <option value="7">7 ngày</option>
            <option value="30">30 ngày</option>
            <option value="90">3 tháng</option>
            <option value="365">1 năm</option>
        </select>

        <h5 class="mt-3">Lọc theo ngày tùy chỉnh</h5>
        <label>Từ ngày:</label>
        <input type="date" id="date_from" class="form-control" />
        <label>Đến ngày:</label>
        <input type="date" id="date_to" class="form-control" />
        <button id="filterButton" class="btn btn-primary mt-2">Lọc</button>
    </div>

    <div class="col-md-4">
        <!-- Legend / Chú thích -->
        <h5>📋 Chú thích biểu đồ</h5>
        <ul class="list-unstyled mt-2">
            <li><span style="color:#0b62a4; font-weight:bold;">■</span> Đơn hàng (sold)</li>
            <li><span style="color:#7a92a3; font-weight:bold;">■</span> Số lượng bán ra (quantity)</li>
            <li><span style="color:#f39c12; font-weight:bold;">■</span> Doanh thu (revenue)</li>
            <li><span style="color:#8e44ad; font-weight:bold;">■</span> Lợi nhuận (profit)</li>
        </ul>
    </div>
</div>

<!-- Biểu đồ -->
<div class="row mt-4">
    <div class="col-12">
        <h4 class="fw-bold mb-3">📈 Biểu đồ thống kê</h4>
        <div id="myfirstchart" class="border rounded p-3 shadow-sm bg-white" style="height: 380px;"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/raphael/2.3.0/raphael.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/morris.js/0.5.1/morris.min.js"></script>

    <script>
        $(document).ready(function () {
            let ChartMorris = new Morris.Line({
                element: 'myfirstchart',
                data: [],
                parseTime: true,
                xkey: 'date',
                ykeys: ['sold', 'quantity', 'revenue', 'profit'],
                labels: ["Đơn hàng", "Số lượng", "Doanh thu", "Lợi nhuận"],
                lineWidth: 3,
                resize: true,
                xLabelAngle: 45,
                xLabelFormat: function (x) { return new Date(x).toLocaleDateString("vi-VN"); },
                hoverCallback: function (i, opts, content, row) {
                    return `
                        <div style="padding:6px">
                            <strong>${new Date(row.date).toLocaleDateString("vi-VN")}</strong><br>
                            🧾 Đơn hàng: ${row.sold}<br>
                            📦 Số lượng: ${row.quantity}<br>
                            💰 Doanh thu: ${row.revenue.toLocaleString("vi-VN")} đ<br>
                            💵 Lợi nhuận: ${row.profit.toLocaleString("vi-VN")} đ
                        </div>`;
                }
            });

            function parseChart(data) {
                return data?.map(item => ({
                    date: item.date,
                    sold: item.sold,
                    quantity: item.quantity,
                    revenue: item.revenue,
                    profit: item.profit
                })) || [];
            }

            function LoadChartDefault() {
                $.ajax({
                    url: "@Url.Action("GetChartData", "Dashboard")",
                    type: "POST",
                    dataType: "json",
                    success: function (data) {
                        ChartMorris.setData(parseChart(data));
                    },
                    error: function() {
                        ChartMorris.setData([]); // Tránh lỗi undefined
                    }
                });
            }

            LoadChartDefault();

            window.addEventListener("storage", function (e) {
                if (e.key === "chartUpdate") {
                    LoadChartDefault();
                }
            });

            // Filter nhanh 7/30/90/365
            $(".filter-select").change(function () {
                let days = $(this).val();
                if (!days) return;

                let endDate = new Date();
                let startDate = new Date(endDate.getTime() - days * 24 * 60 * 60 * 1000);

                $.ajax({
                    url: "@Url.Action("GetChartDateBySelect", "Dashboard")",
                    type: "POST",
                    data: {
                        startDate: startDate.toISOString(),
                        endDate: endDate.toISOString()
                    },
                    success: function (data) {
                        ChartMorris.setData(parseChart(data));
                    },
                    error: function() {
                        ChartMorris.setData([]);
                    }
                });
            });

            // Filter custom date
            $("#filterButton").click(function () {
                let start = $("#date_from").val();
                let end = $("#date_to").val();
                if (!start || !end) {
                    alert("Vui lòng chọn đầy đủ ngày từ và đến.");
                    return;
                }

                $.ajax({
                    url: "@Url.Action("GetChartDateBySelect", "Dashboard")",
                    type: "POST",
                    data: { startDate: start, endDate: end },
                    success: function (data) {
                        ChartMorris.setData(parseChart(data));
                    },
                    error: function() {
                        ChartMorris.setData([]);
                    }
                });
            });
        });
    </script>
}
