@model IEnumerable<CategoryModel>

@{
    ViewData["title"] = "Danh mục";

    Paginate pager = new Paginate();

    int pageNo = 0;

    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;

        pageNo = pager.CurrentPage;
    }

}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>

    <a class="btn btn-primary" asp-action="Create" asp-controller="Category">Thêm danh mục</a>
   
    <table class="table" id="myTable">
        <thead>
            <tr>
                <th>Id</th>
                <th>Tên danh mục</th>
                <th>Mô tả danh mục</th>
                <th>Slug danh mục</th>
                <th>Trạng thái</th>
                <th>Tùy chỉnh</th>

            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderBy(x => x.Id))
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@Html.Raw(@item.Description)</td>
                    <td> @item.Slug </td>
                    <td> 
                        @if(item.Status == 1)
                        {
                            <span class="text text-success">Hiển thị</span>
                        }else{
                            <span class="text text-danger">Ẩn</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-warning btn-sm" asp-action="Edit" asp-controller="Category" asp-route-Id="@item.Id">Edit</a>
                        <a class="btn btn-danger btn-sm confirmDeletion" asp-action="Delete" asp-controller="Category" asp-route-Id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // Kiểm tra xem DataTable đã khởi tạo chưa, tránh lỗi reinitialise
                if (!DataTable.instances?.some(dt => dt.table.id === 'myTable')) {
                    new DataTable('#myTable', {
                        layout: {
                            topStart: {
                                buttons: [
                                    { extend: 'copy', text: '📋 Sao chép' },
                                    { extend: 'csv', text: '📄 Xuất CSV' },
                                    { extend: 'excel', text: '📊 Xuất Excel' },
                                    { extend: 'pdf', text: '🧾 Xuất PDF' },
                                    { extend: 'print', text: '🖨️ In' }
                                ]
                            }
                        },
                        paging: true,
                        lengthChange: false, // ẩn "Show entries"
                        info: false,         // ẩn "Showing 1 to 25 of X entries"
                        language: {
                            search: " Tìm kiếm:",
                            zeroRecords: "Không tìm thấy kết quả phù hợp",
                            emptyTable: "Không có dữ liệu",
                            paginate: {
                                next: "Trang sau",
                                previous: "Trang trước"
                            }
                        }
                    });
                }
            });
        </script>
    }

    
</body>
</html>