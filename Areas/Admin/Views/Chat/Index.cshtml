@{
    Layout = null;
    ViewData["Title"] = "Admin Chat";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <style>
        body {
            display: flex;
            height: 100vh;
            background-color: #f5f6fa;
            margin: 0;
        }

        #user-list {
            width: 280px;
            background: #fff;
            border-right: 1px solid #ddd;
            overflow-y: auto;
        }

            #user-list .header {
                padding: 10px 15px;
                background: #f0f0f0;
                font-weight: 600;
                border-bottom: 1px solid #ddd;
            }

            #user-list .user {
                padding: 10px 15px;
                border-bottom: 1px solid #eee;
                cursor: pointer;
                transition: background 0.2s;
            }

                #user-list .user:hover {
                    background: #f5faff;
                }

                #user-list .user.active {
                    background: #e9f5ff;
                    font-weight: bold;
                }

        #chat-area {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        #chat-box {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            background: #fafafa;
        }

        .chat-row {
            display: flex;
            margin-bottom: 10px;
            align-items: flex-end;
        }

            .chat-row.admin {
                justify-content: flex-end;
            }

        .chat-bubble {
            padding: 10px 15px;
            border-radius: 16px;
            max-width: 65%;
            word-wrap: break-word;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        }

        .user-msg {
            background: #0084ff;
            color: white;
        }

        .admin-msg {
            background: #28a745;
            color: white;
        }

        #chat-input {
            display: flex;
            padding: 10px;
            background: white;
            border-top: 1px solid #ddd;
        }

            #chat-input input {
                flex: 1;
                border-radius: 20px;
                border: 1px solid #ccc;
                padding: 10px 15px;
                outline: none;
                transition: border 0.2s;
            }

                #chat-input input:focus {
                    border-color: #007bff;
                }

            #chat-input button {
                margin-left: 10px;
                border-radius: 20px;
                padding: 10px 20px;
            }

        #empty-message {
            text-align: center;
            margin-top: 100px;
            color: #aaa;
            font-style: italic;
        }
    </style>
</head>

<body>
    <!-- Danh sách user -->
    <div id="user-list">
        <div class="header">🧑‍💻 Người dùng online</div>
        <div id="users"></div>
    </div>

    <!-- Khu vực chat -->
    <div id="chat-area">
        <div id="chat-box">
            <div id="empty-message">Chọn một người dùng để bắt đầu trò chuyện</div>
        </div>
        <div id="chat-input">
            <input type="text" id="msg" placeholder="Nhập tin nhắn..." autocomplete="off" />
            <button id="send-btn" class="btn btn-primary">Gửi</button>
        </div>
    </div>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .configureLogging(signalR.LogLevel.Information)
            .build();

        const usersDiv = document.getElementById("users");
        const chatBox = document.getElementById("chat-box");
        const msgInput = document.getElementById("msg");
        const sendBtn = document.getElementById("send-btn");
        const emptyMsg = document.getElementById("empty-message");

        let selectedUser = null;

        // 🟢 Cập nhật danh sách user online
        connection.on("UpdateUserList", (users) => {
            usersDiv.innerHTML = "";
            console.log("📋 User list received:", users);

            if (!users || users.length === 0) {
                usersDiv.innerHTML = "<div class='p-3 text-muted small'>Không có ai online</div>";
                return;
            }

            // ✅ users = [{ connectionId, userName }]
            users.forEach(u => {
                const div = document.createElement("div");
                div.className = "user";
                div.textContent = `${u.userName} (${u.connectionId.slice(0, 5)})`;
                div.dataset.conn = u.connectionId;
                div.onclick = () => selectUser(div);
                usersDiv.appendChild(div);
            });
        });

        // 🟢 Nhận tin nhắn từ user
        connection.on("ReceiveMessage", (sender, message, connId) => {
            // Nếu đang chat đúng user thì hiển thị
            if (connId && connId === selectedUser)
                appendMessage(sender, message, sender === "Admin");
        });

        // 🟢 Kết nối SignalR
        connection.start()
            .then(() => console.log("✅ SignalR connected"))
            .catch(err => console.error("❌ SignalR error:", err));

        // 🟢 Gửi tin nhắn
        sendBtn.addEventListener("click", async () => {
            await sendMessage();
        });

        msgInput.addEventListener("keydown", async (e) => {
            if (e.key === "Enter") await sendMessage();
        });

        async function sendMessage() {
            const msg = msgInput.value.trim();
            if (!msg) return;
            if (!selectedUser) {
                alert("Vui lòng chọn người dùng để gửi tin nhắn.");
                return;
            }

            try {
                await connection.invoke("SendMessageToUser", selectedUser, msg);
                appendMessage("Admin", msg, true);
                msgInput.value = "";
            } catch (e) {
                console.error(e);
                alert("Không thể gửi tin nhắn.");
            }
        }

        // 🟢 Chọn user và tải lịch sử chat
        async function selectUser(div) {
            document.querySelectorAll("#user-list .user").forEach(u => u.classList.remove("active"));
            div.classList.add("active");
            selectedUser = div.dataset.conn;
            chatBox.innerHTML = "";

            try {
                const res = await fetch(`/chat/history/${selectedUser}`);
                if (!res.ok) throw new Error("Không tải được lịch sử chat");
                const data = await res.json();

                if (data.length === 0) {
                    chatBox.innerHTML = "<div id='empty-message'>Chưa có tin nhắn nào</div>";
                } else {
                    data.forEach(msg => {
                        appendMessage(msg.senderId, msg.message, msg.senderId === "Admin");
                    });
                }
            } catch (e) {
                console.error(e);
                chatBox.innerHTML = "<div id='empty-message'>Không thể tải lịch sử chat</div>";
            }
        }

        // 🟢 Hiển thị tin nhắn
        function appendMessage(sender, message, fromAdmin) {
            if (emptyMsg) emptyMsg.remove();

            const row = document.createElement("div");
            row.className = "chat-row " + (fromAdmin ? "admin" : "user");

            const bubble = document.createElement("div");
            bubble.className = "chat-bubble " + (fromAdmin ? "admin-msg" : "user-msg");
            bubble.innerText = `${sender}: ${message}`;

            row.appendChild(bubble);
            chatBox.appendChild(row);
            chatBox.scrollTop = chatBox.scrollHeight;
        }
    </script>

</body>
</html>
